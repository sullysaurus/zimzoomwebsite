---
import '../styles/global.css';

const experiences = [
  { name: 'Pro Booth', tag: 'The crowd-pleaser', image: '/images/pro-real.jpg', copy: 'Studio-quality DSLR portraits, custom prints, a polished host, and instant digital sharing.', tone: 'coral' },
  { name: 'Glam Booth', tag: 'Black, white & iconic', image: '/images/glam.jpg', copy: 'Flattering light, a subtle beauty filter, and timeless monochrome portraits everyone looks good in.', tone: 'cream' },
  { name: '360 Booth', tag: 'Main-character energy', image: '/images/360.jpg', copy: 'Immersive slow-motion videos, custom effects, branded overlays, and instant sharing.', tone: 'blue' },
  { name: 'LITE Booth', tag: 'Small footprint. Big fun.', image: '/images/lite-real.jpg', copy: 'A sleek all-digital selfie station for photos, GIFs, videos, and effortless sharing.', tone: 'yellow' },
  { name: 'Headshots', tag: 'Look like your best self', image: '/images/headshots.jpg', copy: 'On-site photographer, pose coaching, studio lighting, and an instant professional gallery.', tone: 'cream' },
  { name: 'Event Photo', tag: 'Nothing gets missed', image: '/images/event-real.jpg', copy: 'Candid event coverage with pro lighting, fast delivery, and a live shareable gallery.', tone: 'coral' }
];

const reviews = [
  { quote: 'The pictures always turn out amazing and it is such a fun and unique memory to have!', name: 'Nicole B.', event: 'Wedding · Apex, NC' },
  { quote: 'The photo booth made our launch party next-level. It is the perfect icebreaker for any event.', name: 'Hopie A.', event: 'Brand Launch · Raleigh, NC' },
  { quote: 'Best of all, we have photos as proof of the good times. Super high quality and really great people.', name: 'Joseph L.', event: 'Corporate Party · Raleigh, NC' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Extraordinary photo booth experiences for weddings, parties, and brand events across North Carolina." />
    <link rel="icon" href="/images/seal.png" />
    <title>ZimZoom Photo Booth | Bring the party to life</title>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <header class="site-header">
      <a class="wordmark" href="#top" aria-label="ZimZoom home">ZIM<span>ZOOM</span></a>
      <nav class="desktop-nav" aria-label="Primary navigation">
        <a href="#experiences">Experiences</a>
        <a href="#gallery">Gallery</a>
        <a href="#locations">Locations</a>
        <a href="#reviews">Love notes</a>
      </nav>
      <a class="pill pill-small desktop-book" href="#book">Check your date <span>↗</span></a>
      <button class="menu-button" aria-expanded="false" aria-controls="mobile-nav"><span></span><span></span></button>
      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
        <a href="#experiences">Experiences</a><a href="#gallery">Gallery</a><a href="#locations">Locations</a><a href="#reviews">Love notes</a><a href="#book">Check your date</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-image" role="img" aria-label="Guests celebrating together in a ZimZoom photo booth"></div>
        <div class="hero-wash"></div>
        <div class="hero-copy">
          <p class="eyebrow reveal">North Carolina's party people</p>
          <h1 class="reveal"><span class="hero-long">Extraordinary</span><br />Photo Booth<br />Experiences</h1>
          <p class="hero-claim reveal"><i>the</i> <strong>TOP RATED</strong> <span>NC Photo Booth</span></p>
          <div class="hero-bottom reveal">
            <p>Photo booth experiences that get everybody in the frame and keep the energy high.</p>
            <a class="pill hero-cta" href="#book">Check your date <span>↗</span></a>
            <a class="circle-link" href="#experiences" aria-label="Explore experiences">↓</a>
          </div>
        </div>
        <div class="photo-stamp" aria-hidden="true"><span>TOP RATED</span><b>NC</b><span>PHOTO BOOTH</span></div>
        <div class="ticker" aria-hidden="true"><div>WEDDINGS ✦ BRAND ACTIVATIONS ✦ PROMS ✦ PARTIES ✦ UNIVERSITY EVENTS ✦ WEDDINGS ✦ BRAND ACTIVATIONS ✦ PROMS ✦ PARTIES ✦</div></div>
      </section>

      <section class="intro section-pad">
        <div class="section-number">01 / ABOUT</div>
        <div class="intro-copy reveal">
          <h2>Not just a booth.<br />A <span>party magnet.</span></h2>
          <p>We bring the flattering light, crisp cameras, custom design, and humans who know how to work a room. You bring your people.</p>
          <a class="text-link" href="#book">LET'S MAKE SOMETHING FUN <span>↗</span></a>
        </div>
        <figure class="tilt-photo reveal">
          <img src="/images/party.jpg" alt="Guests celebrating at a ZimZoom event" loading="lazy" />
          <figcaption>Proof the party happened</figcaption>
        </figure>
      </section>

      <section class="proof-band" aria-label="ZimZoom by the numbers">
        <div class="proof-intro"><span>★★★★★</span><p>Top-rated photo booth experiences across North Carolina</p></div>
        <div class="proof-stat"><b>6,535<sup>+</sup></b><span>Events</span></div>
        <div class="proof-stat"><b>13.7M<sup>+</sup></b><span>Photos</span></div>
        <div class="proof-stat"><b>29.6M<sup>+</sup></b><span>Smiles</span></div>
      </section>

      <section class="client-proof section-pad">
        <div class="section-number">TRUSTED BY TEAMS AT</div>
        <div class="logo-row">
          <img src="/images/logo-duke.png" alt="Duke University" loading="lazy" />
          <img src="/images/logo-google.png" alt="Google" loading="lazy" />
          <img src="/images/logo-epic.png" alt="Epic Games" loading="lazy" />
          <img src="/images/logo-meta.png" alt="Meta" loading="lazy" />
          <img src="/images/logo-sas.png" alt="SAS" loading="lazy" />
          <img src="/images/logo-nvidia.png" alt="NVIDIA" loading="lazy" />
        </div>
      </section>

      <section class="experiences section-pad" id="experiences">
        <div class="section-heading reveal">
          <div class="section-number">02 / PICK YOUR VIBE</div>
          <h2>Six ways to<br /><i>steal the show.</i></h2>
          <p>Tap a card to see what makes each experience click.</p>
        </div>
        <div class="experience-grid">
          {experiences.map((item, index) => (
            <article class={`experience-card ${item.tone} reveal`}>
              <div class="card-image"><img src={item.image} alt={`${item.name} experience`} loading="lazy" /><span>0{index + 1}</span></div>
              <div class="card-copy"><p>{item.tag}</p><h3>{item.name}</h3><div class="card-detail"><p>{item.copy}</p><a href="#book" aria-label={`Book the ${item.name}`}>↗</a></div></div>
            </article>
          ))}
        </div>
      </section>

      <section class="gallery section-pad" id="gallery">
        <div class="gallery-heading reveal">
          <div class="section-number">03 / THE RECEIPTS</div>
          <h2>Real people.<br /><i>Really good parties.</i></h2>
          <p>Weddings, brand activations, campus celebrations, and the kind of parties people keep talking about.</p>
          <a class="text-link" href="https://photos.zimzoomphotobooth.com/">OPEN THE FULL GALLERY <span>↗</span></a>
        </div>
        <div class="gallery-grid">
          <figure class="gallery-main reveal"><img src="/images/wedding.jpg" alt="Wedding guests posing in oversized glasses" loading="lazy" /><figcaption>Wedding energy</figcaption></figure>
          <figure class="reveal"><img src="/images/gallery-vogue.jpg" alt="Guest posing against a sparkling photo booth backdrop" loading="lazy" /><figcaption>Editorial energy</figcaption></figure>
          <figure class="reveal"><img src="/images/gallery-prints.jpg" alt="Couple looking at their photo booth prints" loading="lazy" /><figcaption>Instant keepsakes</figcaption></figure>
          <figure class="reveal"><img src="/images/gallery-wedding.jpg" alt="Couple celebrating their wedding" loading="lazy" /><figcaption>Just married</figcaption></figure>
          <figure class="reveal"><img src="/images/gallery-dancers.jpg" alt="Three guests striking playful poses against a blue photo booth backdrop" loading="lazy" /><figcaption>Strike a pose</figcaption></figure>
        </div>
        <aside class="customize-card reveal">
          <span>MAKE IT YOURS</span><h3>Your colors.<br />Your backdrop.<br />Your moment.</h3><p>Every experience can be styled with custom graphics, curated backdrops, and a sharing gallery that feels unmistakably yours.</p>
          <div><a href="https://zimzoomphotobooth.com/photo-booth-backdrops/">See backdrops ↗</a><a href="https://zimzoomphotobooth.com/photo-booth-graphic-inspiration/">Explore designs ↗</a></div>
        </aside>
      </section>

      <section class="marquee" aria-label="Service area"><div>RALEIGH ✦ DURHAM ✦ CHARLOTTE ✦ ASHEVILLE ✦ GREENSBORO ✦ WINSTON-SALEM ✦ WILMINGTON ✦</div></section>

      <section class="how section-pad" id="how">
        <div class="how-photo reveal"><img src="/images/hero.jpg" alt="Friends celebrating together in a ZimZoom photo booth" loading="lazy" /><div class="scribble">zero<br />awkward<br />photos!</div></div>
        <div class="how-content">
          <div class="section-number">04 / HOW IT WORKS</div>
          <h2 class="reveal">Easy for you.<br /><i>Electric</i> for them.</h2>
          <ol>
            <li class="reveal"><span>01</span><div><h3>Dream it up</h3><p>Tell us the date, the vibe, and what you want guests to remember.</p></div></li>
            <li class="reveal"><span>02</span><div><h3>Make it yours</h3><p>We customize the backdrop, graphics, interface, and sharing experience.</p></div></li>
            <li class="reveal"><span>03</span><div><h3>Show up & shine</h3><p>Our crew handles setup, hosting, and every camera-ready detail.</p></div></li>
            <li class="reveal"><span>04</span><div><h3>Keep everything</h3><p>Your complete gallery is ready to relive and share long after the last song.</p></div></li>
          </ol>
        </div>
      </section>

      <section class="locations section-pad" id="locations">
        <div class="location-copy reveal"><div class="section-number">05 / WE COME TO YOU</div><h2>One team.<br /><i>All over NC.</i></h2><p>From mountain weddings to downtown launches and coastal celebrations, our crews bring the complete experience to your venue.</p><a class="pill" href="#book">Check your location <span>↗</span></a></div>
        <div class="location-list">
          {['Raleigh', 'Durham', 'Charlotte', 'Asheville', 'Greensboro', 'Winston-Salem', 'Wilmington'].map((city, index) => <div class="reveal"><span>0{index + 1}</span><h3>{city}</h3><b>NC</b></div>)}
        </div>
      </section>

      <section class="reviews section-pad" id="reviews">
        <div class="review-title"><div class="section-number">06 / LOVE NOTES</div><h2>They said it.<br /><i>We blushed.</i></h2><div class="rating">★★★★★ <span>Top rated across NC</span></div></div>
        <div class="review-list">
          {reviews.map((review, index) => (
            <blockquote class="reveal"><span>“</span><p>{review.quote}</p><footer><b>{review.name}</b><small>{review.event}</small><em>0{index + 1}</em></footer></blockquote>
          ))}
        </div>
      </section>

      <section class="faq section-pad" id="faq">
        <div class="faq-heading reveal"><div class="section-number">07 / GOOD TO KNOW</div><h2>Questions,<br /><i>answered.</i></h2><p>Still wondering about something? Call or text us at <a href="tel:9196700250">919-670-0250</a>.</p></div>
        <div class="faq-list">
          <details open><summary>What does a ZimZoom experience cost?<span>+</span></summary><p>Pricing depends on your date, location, event length, and chosen experience. Send your event details and we’ll return clear options built around your celebration.</p></details>
          <details><summary>How much space do you need?<span>+</span></summary><p>Most experiences fit comfortably in a compact event footprint. We’ll confirm the ideal placement, power, and access requirements with your venue before event day.</p></details>
          <details><summary>Does a host come with the booth?<span>+</span></summary><p>Our Pro, Glam, and 360 experiences include a professional host or producer. Hosting is optional for some LITE Booth setups.</p></details>
          <details><summary>Can we customize the design?<span>+</span></summary><p>Absolutely. We can tailor the graphics, interface, backdrop, photo layout, and sharing experience to complement your event or brand.</p></details>
          <details><summary>When do we get the gallery?<span>+</span></summary><p>Guests can share during the event, and you’ll receive access to the complete digital gallery for reliving and sharing afterward.</p></details>
          <details><summary>How far do you travel?<span>+</span></summary><p>We serve events across North Carolina, including Raleigh, Durham, Charlotte, Asheville, Greensboro, Winston-Salem, and Wilmington. Ask us about destinations beyond those areas.</p></details>
        </div>
      </section>

      <section class="book section-pad" id="book">
        <div class="book-copy reveal"><div class="section-number">08 / YOUR TURN</div><h2>Let’s make<br />some <i>noise.</i></h2><p>Tell us a little about your event. We’ll confirm availability and send options that fit your crowd.</p><a href="tel:9196700250">Prefer to talk? 919-670-0250</a></div>
        <form class="booking-form reveal" action="https://zimzoomphotobooth.com/book-us/" method="get">
          <label><span>Your name</span><input name="name" autocomplete="name" placeholder="First & last" required /></label>
          <label><span>Email</span><input type="email" name="email" autocomplete="email" placeholder="you@email.com" required /></label>
          <label><span>Event date</span><input type="date" name="date" required /></label>
          <label><span>Event type</span><select name="eventType" required><option value="">Choose one</option><option>Wedding</option><option>Corporate event</option><option>School / university</option><option>Party</option><option>Marketing event</option><option>Other</option></select></label>
          <label class="full"><span>What are you imagining?</span><textarea name="message" placeholder="Venue, guest count, favorite experience, dream vibe…"></textarea></label>
          <button class="submit-button" type="submit"><span>CONTINUE TO AVAILABILITY</span><b>↗</b></button>
          <p class="form-note">You’ll continue to ZimZoom’s secure live booking request.</p>
        </form>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-top"><div class="wordmark footer-mark">ZIM<span>ZOOM</span></div><p>Extraordinary photo booth experiences<br />across North Carolina.</p><a href="#top">BACK TO TOP ↑</a></div>
      <div class="footer-bottom"><p>© {new Date().getFullYear()} ZimZoom Photo Booth</p><a class="site-credit" href="https://dannysullivan.ai" target="_blank" rel="noopener noreferrer">Website by Danny Sullivan ↗</a><div><a href="https://www.instagram.com/zimzoomphotobooth/">Instagram</a><a href="mailto:hello@zimzoomphotobooth.com">Email</a><a href="tel:9196700250">Call</a></div></div>
    </footer>

    <script>
      const menuButton = document.querySelector('.menu-button');
      const mobileNav = document.querySelector('.mobile-nav');
      menuButton?.addEventListener('click', () => {
        const open = menuButton.getAttribute('aria-expanded') === 'true';
        menuButton.setAttribute('aria-expanded', String(!open));
        mobileNav?.classList.toggle('open', !open);
      });
      mobileNav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        mobileNav.classList.remove('open'); menuButton?.setAttribute('aria-expanded', 'false');
      }));
      const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      }), { threshold: .12 });
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      const dateInput = document.querySelector('input[type="date"]');
      if (dateInput instanceof HTMLInputElement) dateInput.min = new Date().toISOString().split('T')[0];
    </script>
  </body>
</html>
